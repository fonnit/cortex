# Cortex v1 Mac worker env. Copy to .env.daemon and fill in.
# Loaded by tsx via --env-file=.env.daemon, OR by your launchd plist's
# EnvironmentVariables block.

# ─── Clerk Machine Token (worker auth) ──────────────────────────────────────
# 1. In Clerk dashboard → Machines (or Applications → Machine Tokens)
# 2. Create a Machine named "Cortex worker"
# 3. Copy client_id + client_secret (shown once at creation)
CLERK_DOMAIN=https://<your-instance>.clerk.accounts.dev
CORTEX_CLIENT_ID=
CORTEX_CLIENT_SECRET=

# ─── Cortex API base URL ────────────────────────────────────────────────────
# Production:
CORTEX_API_BASE_URL=https://cortex.fonnit.com

# ─── Anthropic API (worker classifies via SDK) ──────────────────────────────
# After 2026-06-15: bills against your Max $100/mo API credit pool.
ANTHROPIC_API_KEY=

# ─── Optional overrides ─────────────────────────────────────────────────────
# Archive root override (default: ~/Documents/CortexArchive). Useful if your
# iCloud "Desktop & Documents Folders" toggle is OFF and you want to point
# the worker somewhere specific.
# CORTEX_ARCHIVE_ROOT=/Users/dfonnegrag/Documents/CortexArchive

# Classifier model override (default: claude-haiku-4-5).
# CORTEX_CLASSIFY_MODEL=claude-haiku-4-5
