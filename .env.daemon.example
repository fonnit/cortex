# Cortex v1 Mac worker env. Copy this file to .env.daemon (which is
# gitignored) and fill in the real values there. Do NOT put secrets in this
# .example file — it is checked into git.

# ─── Clerk Machine Token (worker auth) ──────────────────────────────────────
# In Clerk dashboard → Configure → Machine Tokens (or API Keys → Machine).
# Create a Machine named "Cortex worker"; copy the single secret shown.
# The secret starts with `ak_...`. It is used DIRECTLY as the Bearer header;
# there is no /oauth/token exchange.
CORTEX_MACHINE_SECRET=ak_REPLACE_ME

# ─── Cortex API base URL ────────────────────────────────────────────────────
CORTEX_API_BASE_URL=https://cortex.fonnit.com

# ─── Anthropic API (worker classifies via SDK) ──────────────────────────────
# After 2026-06-15: bills against your Max $100/mo API credit pool.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ─── Optional overrides ─────────────────────────────────────────────────────
# Archive root override (default: ~/Documents/CortexArchive). Useful if your
# iCloud "Desktop & Documents Folders" toggle is OFF and you want to point
# the worker somewhere specific.
# CORTEX_ARCHIVE_ROOT=/Users/dfonnegrag/Documents/CortexArchive

# Classifier model override (default: claude-haiku-4-6).
# CORTEX_CLASSIFY_MODEL=claude-haiku-4-6
