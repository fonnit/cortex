// Cortex v1 — single-operator triage queue. No tenancy.
// Auth: Clerk session (browser) OR Clerk M2M token (worker). The middleware
// gates access by CORTEX_OWNER_CLERK_ID env var. There is no User table —
// "the owner" is whoever is allowed past the gate.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// State machine (Item.status):
//
//   pending_classification → pending_review → approved_pending_move → filed
//                          ↘ rejected
//
// Terminal failures: classification_failed, move_failed, source_missing,
// source_changed, unsupported_type (surfaced in UI Failed tab).
// ─────────────────────────────────────────────────────────────────────────────

enum ItemStatus {
  pending_classification
  pending_review
  approved_pending_move
  filed
  rejected
  classification_failed
  move_failed
  source_missing
  source_changed
  unsupported_type
}

enum DecisionAction {
  approve
  move
  reject
  create_folder
  retry
  readd
  delete_record
}

enum ExtractionKind {
  text
  image
  pdf_native
  unsupported
}

model Folder {
  id        String  @id @default(cuid())

  parentId  String?
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  Folder[] @relation("FolderTree")

  name      String
  path      String  @unique  // global; e.g. /Finance/Taxes/2025
  isSeed    Boolean @default(false)

  createdAt DateTime @default(now())

  items            Item[]      @relation("ItemFinalFolder")
  decisionsTo      Decision[]  @relation("DecisionToFolder")
  decisionsFrom    Decision[]  @relation("DecisionFromFolder")
  decisionsCreated Decision[]  @relation("DecisionFolderCreated")

  @@index([parentId])
  @@map("Folder")
}

model Item {
  id                 String          @id @default(cuid())

  sourcePath         String
  sha256             String          @unique
  mimeType           String?
  sizeBytes          Int

  capturedAt         DateTime        @default(now())

  status             ItemStatus      @default(pending_classification)

  // Worker single-flight (managed by /api/items/claim)
  leasedAt           DateTime?
  attempts           Int             @default(0)

  // Classification output (set by worker via /api/items/[id]/classification)
  proposalCandidates Json?
  proposedFolderId   String?
  confidence         Float?
  classifiedAt       DateTime?
  extractionKind     ExtractionKind?
  extractionMs       Int?
  extractedCharCount Int?

  // Final filing destination
  folderId           String?
  folder             Folder?         @relation("ItemFinalFolder", fields: [folderId], references: [id], onDelete: SetNull)
  finalPath          String?

  // Failure recovery (Re-add supersedes Item)
  supersededByItemId String?         @unique
  supersededBy       Item?           @relation("ItemSuperseded", fields: [supersededByItemId], references: [id], onDelete: SetNull)
  supersedes         Item?           @relation("ItemSuperseded")

  decisions          Decision[]

  @@index([status])
  @@index([status, leasedAt])
  @@map("Item")
}

model Decision {
  id                 String         @id @default(cuid())
  itemId             String
  item               Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)

  action             DecisionAction
  fromFolderId       String?
  fromFolder         Folder?        @relation("DecisionFromFolder", fields: [fromFolderId], references: [id], onDelete: SetNull)
  toFolderId         String?
  toFolder           Folder?        @relation("DecisionToFolder", fields: [toFolderId], references: [id], onDelete: SetNull)
  folderCreatedId    String?
  folderCreated      Folder?        @relation("DecisionFolderCreated", fields: [folderCreatedId], references: [id], onDelete: SetNull)
  chosenProposalRank Int?
  rationale          String?

  createdAt          DateTime       @default(now())

  @@index([itemId, createdAt])
  @@map("Decision")
}
