// Cortex v1 — single-operator triage queue + Q&A.
// Embeddings: OpenAI text-embedding-3-small @ 512 dims, halfvec in pgvector.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector", schema: "public")]
}

enum ItemStatus {
  pending_classification
  pending_review
  approved_pending_move
  filed
  rejected
  classification_failed
  move_failed
  source_missing
  source_changed
  unsupported_type
}

enum DecisionAction {
  approve
  move
  reject
  create_folder
  retry
  readd
  delete_record
}

enum ExtractionKind {
  // v1 legacy values (kept for historical rows; new ingest uses the source-specific values below)
  text
  image
  pdf_native
  unsupported

  // v2 source-specific values — the source of the extracted text
  plain_text   // .txt / .md (fs.readFile)
  docx         // .docx (mammoth)
  pdf_text     // .pdf via pdf-parse (text layer present)
  ocr_image    // .png/.jpg/.heic via macOS Vision OCR
  ocr_pdf      // .pdf via PDFKit page rasterize + Vision OCR (scan-only)
}

model Folder {
  id        String  @id @default(cuid())

  parentId  String?
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  Folder[] @relation("FolderTree")

  name      String
  path      String  @unique
  isSeed    Boolean @default(false)

  createdAt DateTime @default(now())

  items            Item[]      @relation("ItemFinalFolder")
  decisionsTo      Decision[]  @relation("DecisionToFolder")
  decisionsFrom    Decision[]  @relation("DecisionFromFolder")
  decisionsCreated Decision[]  @relation("DecisionFolderCreated")

  @@index([parentId])
  @@map("Folder")
}

model Item {
  id                 String          @id @default(cuid())

  sourcePath         String
  sha256             String          @unique
  mimeType           String?
  sizeBytes          Int

  capturedAt         DateTime        @default(now())

  status             ItemStatus      @default(pending_classification)

  // Worker single-flight (classify + move stages share these — sequential lifecycle)
  leasedAt           DateTime?
  attempts           Int             @default(0)

  // Classification output
  proposalCandidates Json?
  proposedFolderId   String?
  confidence         Float?
  classifiedAt       DateTime?
  extractionKind     ExtractionKind?
  extractionMs       Int?
  extractedCharCount Int?
  extractedText      String?         // FULL extracted text — classify truncates at prompt-build only; RAG uses full

  // Filename suggestion + final filename
  suggestedFilename  String?         // Haiku-proposed, 1-60 chars, no extension
  finalFilename      String?         // user-confirmed/edited; basename for move

  // Final filing destination
  folderId           String?
  folder             Folder?         @relation("ItemFinalFolder", fields: [folderId], references: [id], onDelete: SetNull)
  finalPath          String?

  // Embedding state (independent of classify/move lifecycle — needs its own lease/attempts)
  chunkedAt          DateTime?       // NULL = not yet chunked + embedded
  chunkError         String?         // last embedding error (for retry surfacing)
  chunkLeasedAt      DateTime?
  chunkAttempts      Int             @default(0)

  // Failure recovery (Re-add supersedes Item)
  supersededByItemId String?         @unique
  supersededBy       Item?           @relation("ItemSuperseded", fields: [supersededByItemId], references: [id], onDelete: SetNull)
  supersedes         Item?           @relation("ItemSuperseded")

  decisions          Decision[]
  chunks             ItemChunk[]

  @@index([status])
  @@index([status, leasedAt])
  @@index([status, chunkedAt])
  @@index([chunkedAt, chunkLeasedAt])
  @@map("Item")
}

model ItemChunk {
  id        String @id @default(cuid())
  itemId    String
  item      Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  ord       Int     // chunk order within item (0, 1, 2, ...)
  text      String  // raw chunk text (for citation snippets)
  embedding Unsupported("halfvec(512)")

  createdAt DateTime @default(now())

  @@index([itemId, ord])
  @@map("ItemChunk")
}

model Decision {
  id                 String         @id @default(cuid())
  itemId             String
  item               Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)

  action             DecisionAction
  fromFolderId       String?
  fromFolder         Folder?        @relation("DecisionFromFolder", fields: [fromFolderId], references: [id], onDelete: SetNull)
  toFolderId         String?
  toFolder           Folder?        @relation("DecisionToFolder", fields: [toFolderId], references: [id], onDelete: SetNull)
  folderCreatedId    String?
  folderCreated      Folder?        @relation("DecisionFolderCreated", fields: [folderCreatedId], references: [id], onDelete: SetNull)
  chosenProposalRank Int?
  rationale          String?

  createdAt          DateTime       @default(now())

  @@index([itemId, createdAt])
  @@map("Decision")
}
