// Cortex v1 — triage queue rebuild
// Source of truth: ~/.claude/plans/compressed-wobbling-treehouse.md
// Design doc: ~/.gstack/projects/fonnit-cortex/dfonnegrag-main-design-20260512-233606.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url is in prisma.config.ts per Prisma 7 conventions
}

// ─────────────────────────────────────────────────────────────────────────────
// State machine (Item.status):
//
//   ┌───────────────────────────┐
//   │ pending_classification    │  ← cortex add creates row here
//   └────────────┬──────────────┘
//                │ worker classifies via Anthropic SDK + Haiku
//                ▼
//   ┌───────────────────────────┐
//   │ pending_review            │  ← triage UI shows this
//   └────────────┬──────────────┘
//                │ human picks: approve / move / reject / create-folder
//                ▼
//   ┌───────────────────────────┐    ┌─────────────┐
//   │ approved_pending_move     │    │ rejected    │  (terminal)
//   └────────────┬──────────────┘    └─────────────┘
//                │ worker moves file on FS
//                ▼
//   ┌───────────────────────────┐
//   │ filed                     │  (terminal — happy path)
//   └───────────────────────────┘
//
// Terminal failure lanes (surfaced in UI Failed tab with Retry/Re-add/Delete):
//   classification_failed  ← attempts ≥ 3 during classify
//   move_failed            ← mv ENOENT / EPERM / dest exists with diff sha
//   source_missing         ← worker found source gone at classify time
//   source_changed         ← worker re-hash at move time didn't match
//   unsupported_type       ← text-extract returned 'unsupported'
// ─────────────────────────────────────────────────────────────────────────────

enum ItemStatus {
  pending_classification
  pending_review
  approved_pending_move
  filed
  rejected
  classification_failed
  move_failed
  source_missing
  source_changed
  unsupported_type
}

enum DecisionAction {
  approve
  move
  reject
  create_folder
  retry
  readd
  delete_record
}

enum ExtractionKind {
  text
  image
  pdf_native
  unsupported
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  createdAt DateTime @default(now())

  items     Item[]
  folders   Folder[]
  decisions Decision[]

  @@map("User")
}

model Folder {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentId  String?
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  Folder[] @relation("FolderTree")

  name      String
  path      String  // app-maintained materialized path, e.g. /Finance/Taxes/2025
  isSeed    Boolean @default(false)

  createdAt DateTime @default(now())

  items            Item[]      @relation("ItemFinalFolder")
  decisionsTo      Decision[]  @relation("DecisionToFolder")
  decisionsFrom    Decision[]  @relation("DecisionFromFolder")
  decisionsCreated Decision[]  @relation("DecisionFolderCreated")

  @@unique([userId, path])
  @@index([userId, parentId])
  @@map("Folder")
}

model Item {
  id                 String          @id @default(cuid())
  userId             String
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Source file (local FS)
  sourcePath         String
  sha256             String
  mimeType           String?
  sizeBytes          Int

  capturedAt         DateTime        @default(now())

  // State machine
  status             ItemStatus      @default(pending_classification)

  // Lease for worker single-flight (managed by /api/items/claim)
  leasedAt           DateTime?
  attempts           Int             @default(0)

  // Classification output (set by worker via /api/items/[id]/classification)
  proposalCandidates Json?
  proposedFolderId   String?
  proposedNewFolder  String?
  confidence         Float?
  classifiedAt       DateTime?
  extractionKind     ExtractionKind?
  extractionMs       Int?
  extractedCharCount Int?

  // Final filing destination
  folderId           String?
  folder             Folder?         @relation("ItemFinalFolder", fields: [folderId], references: [id], onDelete: SetNull)
  finalPath          String?

  // Failure recovery (Re-add creates a new Item that supersedes the old one)
  supersededByItemId String?         @unique
  supersededBy       Item?           @relation("ItemSuperseded", fields: [supersededByItemId], references: [id], onDelete: SetNull)
  supersedes         Item?           @relation("ItemSuperseded")

  decisions          Decision[]

  @@unique([userId, sha256])
  @@index([userId, status])
  @@index([status, leasedAt])
  @@map("Item")
}

model Decision {
  id                 String         @id @default(cuid())
  itemId             String
  item               Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  action             DecisionAction
  fromFolderId       String?
  fromFolder         Folder?        @relation("DecisionFromFolder", fields: [fromFolderId], references: [id], onDelete: SetNull)
  toFolderId         String?
  toFolder           Folder?        @relation("DecisionToFolder", fields: [toFolderId], references: [id], onDelete: SetNull)
  folderCreatedId    String?
  folderCreated      Folder?        @relation("DecisionFolderCreated", fields: [folderCreatedId], references: [id], onDelete: SetNull)
  chosenProposalRank Int?
  rationale          String?

  createdAt          DateTime       @default(now())

  @@index([itemId, createdAt])
  @@map("Decision")
}
