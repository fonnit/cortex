# Cortex v1 Mac worker env. Copy this file to .env.daemon (which is
# gitignored at agent/.env.daemon) and fill in the real values there.
# Do NOT put secrets in this .example file — it is checked into git.

# ─── Clerk M2M (worker auth) ────────────────────────────────────────────────
# In the Clerk dashboard:
#   1. Create TWO Machines: "cortex-worker" and "cortex-backend".
#   2. On cortex-worker → Scopes → add "cortex-backend" as an allowed target.
#   3. View the cortex-worker machine secret (ak_...). Paste it here.
#   4. View the cortex-backend machine secret (a DIFFERENT ak_...). Add it
#      to Vercel env as CLERK_MACHINE_SECRET_KEY for Production.
#
# The worker uses this secret to mint short-lived M2M tokens (mt_...) per
# request and sends them as `Authorization: Bearer mt_...`. The secret itself
# never leaves your Mac.
CLERK_MACHINE_SECRET_KEY=ak_REPLACE_WITH_WORKER_MACHINE_SECRET

# ─── Cortex API base URL ────────────────────────────────────────────────────
CORTEX_API_BASE_URL=https://cortex.fonnit.com

# ─── Anthropic API (worker classifies via SDK) ──────────────────────────────
# After 2026-06-15: bills against your Max $100/mo API credit pool.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ─── OpenAI API (worker embeds extracted text for RAG) ──────────────────────
# Used by agent/src/embed.ts to call text-embedding-3-small @ 512 dims for
# every classified Item. Volume is tiny (cents/month at personal-archive
# scale). Vercel will also need this set (CLERK_MACHINE_SECRET_KEY-style)
# once /api/ask lands in v2.1 — for now only the worker uses it.
OPENAI_API_KEY=sk-REPLACE_ME

# ─── Optional overrides ─────────────────────────────────────────────────────
# Archive root override (default: ~/Documents/CortexArchive).
# CORTEX_ARCHIVE_ROOT=/Users/dfonnegrag/Documents/CortexArchive

# Classifier model override (default: claude-haiku-4-5).
# CORTEX_CLASSIFY_MODEL=claude-haiku-4-5
