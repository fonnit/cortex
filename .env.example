# Neon Postgres
DATABASE_URL=postgresql://...?sslmode=require

# Anthropic (classification)
ANTHROPIC_API_KEY=sk-ant-...

# Langfuse (observability)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
