# Neon Postgres
DATABASE_URL=postgresql://...?sslmode=require

# Anthropic (classification)
ANTHROPIC_API_KEY=sk-ant-...

# Langfuse (observability)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Google OAuth (Gmail + Drive — stored in Keychain at runtime, needed for initial auth)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REFRESH_TOKEN=<refresh token from agent OAuth flow — stored in Vercel env for cron>

# Google Drive
DRIVE_INBOX_FOLDER_ID=<Drive folder ID of _Inbox root>

# Cron auth (Vercel cron resolve job)
CRON_SECRET=your-secret-here

# Cortex API (v1.1) — daemon and consumer authenticate to the Vercel API
# Generate the key: printf "cortex_" && openssl rand -hex 32
# CORTEX_API_URL is your Vercel project URL (e.g., https://cortex.fonnit.com)
# Both must also be set in the Vercel project env (vercel env add)
CORTEX_API_URL=https://your-project.vercel.app
CORTEX_API_KEY=cortex_<openssl rand -hex 32>

# Daemon-only env file (.env.daemon) — same vars MINUS DATABASE_URL,
# loaded by agent/launchd/com.cortex.daemon.plist via --env-file=
# Daemon must NOT have DATABASE_URL in its environment per DAEMON-01.

# Consumer-only env file (.env.consumer) — daemon API access + Langfuse,
# loaded by agent/launchd/com.cortex.consumer.plist
# Consumer relies on the local `claude` CLI's own auth — no ANTHROPIC_API_KEY here.

# Clerk (web app — Phase 2, document now)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
