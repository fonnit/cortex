# Cortex v1 — root env vars (Next.js dev server + prisma seed/migrate).
# Production secrets live in Vercel; copy this to .env.local for local dev.

# ─── Neon Postgres ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://...

# ─── Clerk (browser auth) ───────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_or_live_...
CLERK_SECRET_KEY=sk_test_or_live_...

# ─── Clerk M2M (backend's machine secret, for verifying mt_ tokens) ─────────
# Create the "cortex-backend" Machine in Clerk dashboard; copy its ak_ secret.
CLERK_MACHINE_SECRET_KEY=ak_<cortex-backend's machine secret>

# ─── Single-owner gate ──────────────────────────────────────────────────────
# Cortex v1 is single-operator. Only this Clerk user can access the triage UI.
# Without this set, ANY Clerk-authenticated user at this app can sign in and
# see your archive. Get the value from clerk.com dashboard → Users → your row.
CORTEX_OWNER_CLERK_ID=user_xxxxxxxxxx
