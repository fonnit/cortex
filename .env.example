# Cortex v1 — root env vars (Next.js dev server + prisma seed/migrate).
# Production secrets live in Vercel; copy this to .env.local for local dev.

# ─── Neon Postgres ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://...

# ─── Clerk (browser auth + machine token validation) ────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_or_live_...
CLERK_SECRET_KEY=sk_test_or_live_...

# ─── Optional seed targeting ────────────────────────────────────────────────
# When running `npm run seed`, attach the 22 seeded folders to a specific
# Clerk user instead of creating a placeholder.
# CORTEX_SEED_USER_CLERK_ID=user_xxxxxxxxxx
